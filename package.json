{
  "name": "nextjs-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "eslint": "cross-env TIMING=1 eslint --format=pretty src",
    "eslint:debug": "cross-env TIMING=1 eslint --debug",
    "eslint:fix": "cross-env TIMING=1 eslint --fix --format=pretty src",
    "typecheck": "tsc --noEmit --incremental false",
    "test:watch": "jest --watch",
    "test": "jest",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prepare": "husky install"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.17",
    "caniuse-lite": "^1.0.30001787",
    "clsx": "^2.0.0",
    "lucide-react": "^1.8.0",
    "next": "^15.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "9.25.1",
    "@stylistic/eslint-plugin": "5.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^19.1.8",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "7.0.3",
    "eslint": "9.25.1",
    "eslint-config-next": "^14.2.23",
    "eslint-formatter-compact": "8.40.0",
    "eslint-formatter-pretty": "6.0.1",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "4.3.4",
    "eslint-plugin-deprecation": "3.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-path-alias": "2.1.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "husky": "^9.1.7",
    "jest": "^27.5.1",
    "lint-staged": "^12.5.0",
    "next-router-mock": "^0.9.0",
    "next-sitemap": "^2.5.28",
    "organize-imports-cli": "0.10.0",
    "postcss": "^8.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,scss,md,webmanifest}": [
      "bun eslint:fix"
    ]
  },
  "bun": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint-plugin-import",
        "eslint"
      ]
    },
    "allowedDeprecatedVersions": {
      "source-map-resolve": "*",
      "resolve-url": "*",
      "source-map-url": "*",
      "urix": "*"
    }
  },
  "patchedDependencies": {
    "eslint-plugin-path-alias@2.1.0": "patches/eslint-plugin-path-alias@2.1.0.patch"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}